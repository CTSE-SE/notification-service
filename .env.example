# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL via Amazon RDS) ─────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notification_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── AWS Configuration ────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ─── Amazon SQS ───────────────────────────────────────
SQS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789/order-events-queue
SQS_POLLING_INTERVAL_MS=5000
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20

# ─── Amazon SES ───────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=ShopApp Notifications

# ─── JWT (shared secret – same as User Service) ───────
JWT_SECRET=your_super_secret_jwt_key

# ─── Internal API Key (used by other services) ────────
INTERNAL_API_KEY=your_internal_api_key_shared_with_services
